# ── OpenOctopus Environment Variables ──
# These can be set in .env or in config.json5 (preferred).
# See: ~/.openoctopus/config.json5

# ── Gateway Ports ──
# OPENOCTOPUS_PORT=19790       # HTTP bridge port
# OPENOCTOPUS_WS_PORT=19789    # WebSocket RPC port

# ── Config ──
# OPENOCTOPUS_CONFIG=~/.openoctopus/config.json5
# OPENOCTOPUS_CONFIG_DIR=~/.openoctopus
# OPENOCTOPUS_DATA_DIR=

# ── LLM Provider API Keys ──
# Auto-configured when set (no config.json5 needed):
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=AI...
# ARK_API_KEY=ark-your-key
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
# ARK_CHAT_MODEL=doubao-seed-2-0-code-preview-260215

# ── Channel Tokens ──
# TELEGRAM_BOT_TOKEN=
# DISCORD_BOT_TOKEN=
# SLACK_BOT_TOKEN=

# ── Logging ──
# OPENOCTOPUS_LOG_LEVEL=info
