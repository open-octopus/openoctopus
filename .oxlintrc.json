{
  "plugins": ["unicorn", "typescript", "oxc"],
  "categories": {
    "correctness": "error",
    "perf": "error",
    "suspicious": "error"
  },
  "rules": {
    "curly": "error",
    "typescript/no-explicit-any": "error",
    "typescript/no-unsafe-type-assertion": "off",
    "no-await-in-loop": "off"
  },
  "overrides": [
    {
      "files": ["*.test.ts", "*.integration.test.ts"],
      "rules": {
        "typescript/no-explicit-any": "off"
      }
    }
  ],
  "ignorePatterns": [
    "dist/",
    "node_modules/",
    "coverage/",
    "realms/",
    "skills/",
    "docs/",
    "pnpm-lock.yaml",
    ".claude/"
  ]
}
